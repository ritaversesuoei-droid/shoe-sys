# ============================================================
# 昭栄運輸 運行・勤怠管理システム 環境変数サンプル
# .env.local にコピーして実値を設定してください（.env.local はコミット禁止）。
# ============================================================

# ---- Supabase ----
# ブラウザ公開可能（anon key, RLS で保護）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# サーバー専用（service_role: RLS をバイパスする。絶対に公開しない / NEXT_PUBLIC_ を付けない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- LINE Messaging API（管理者通知 push 用 / 仕様書 F-16, 12.1-#1）----
# トークン・シークレットはコード直書き禁止。環境変数のみ。
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# ---- LINE LIFF（ドライバー認証 / 仕様書 F-01）----
NEXT_PUBLIC_LIFF_ID=your-liff-id
# LIFF が属する「LINEログインチャネル」のチャネルID（IDトークン検証 aud に使用）
LINE_LOGIN_CHANNEL_ID=your-login-channel-id

# 管理者へ警告/業務報告を push する宛先（グループ or ユーザーID）
LINE_ADMIN_TARGET_ID=your-admin-target-id

# ---- アプリ ----
# 署名付きURL生成や絶対URL組み立てに使用
NEXT_PUBLIC_APP_URL=http://localhost:3000
# JST 固定運用。タイムゾーンの基準（仕様書 11.2 移行リスク: 時刻表記ゆれ対策）
APP_TIMEZONE=Asia/Tokyo

# ---- PDF生成（F-17/18）----
# サーバーのChrome/Chromium実行パス。未設定時は環境依存の既定を探索。
PUPPETEER_EXECUTABLE_PATH=

# ---- 据置端末（S-08/09）----
OFFICE_TERMINAL_TOKEN=

# ---- 逆ジオコーディング（F-22）----
# gsi(既定,無料・日本) / google(GOOGLE_MAPS_API_KEY必須) / none
GEOCODER=gsi
GOOGLE_MAPS_API_KEY=

# 配車「流れ表」連携（TROUD由来 Googleスプレッドシート → dispatch_plans）
# 既定は公開シートのCSVエクスポートを直接取得（未設定でOK）。差し替え時のみ指定。
# DISPATCH_SHEET_ID=1yXWWA-wAyUyX2NCrmMcf5RkTCLUonWHPwQH9a39iH6Y
# DISPATCH_SHEET_GID=0
# DISPATCH_SHEET_CSV_URL=（完全なCSVエクスポートURLで上書きする場合）
